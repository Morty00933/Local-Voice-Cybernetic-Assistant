{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (all services)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (job)",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (job)",
          "legendFormat": "{{ job }} errors"
        }
      ]
    },
    {
      "title": "STT Transcription Latency (P95)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(stt_transcription_duration_seconds_bucket[5m]))"
        }
      ]
    },
    {
      "title": "Brain Response Latency (P95)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(brain_response_duration_seconds_bucket[5m]))"
        }
      ]
    },
    {
      "title": "TTS Synthesis Latency (P95)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(tts_synthesis_duration_seconds_bucket[5m]))"
        }
      ]
    },
    {
      "title": "Pipeline E2E Latency (P95)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pipeline_total_duration_seconds_bucket[5m]))"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "{{ job }} (MB)"
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[5m])",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "title": "Active WebSocket Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "active_websocket_sessions"
        }
      ]
    },
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 22 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{ job }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["lvca"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LVCA Dashboard",
  "uid": "lvca-main",
  "version": 1
}
